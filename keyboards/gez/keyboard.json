{
    "keyboard_name": "Gez V1 - Enhanced Split",
    "manufacturer": "Yehonatan Elentok",
    "url": "",
    "maintainer": "Yehonatan Elentok",
    "usb": {
        "vid": "0x444D",
        "pid": "0x3537",
        "device_version": "1.0.0"
    },
    "matrix_size": {
        "cols": 6,
        "rows": 4
    },
    "matrix_pins": {
        "rows": [ "B3", "B1", "E7", "F6"],
        "cols": [ "B4", "D7", "C6", "D4", "D0", "E6" ]
    },
    "diode_direction": "COL2ROW",
    "debounce": 5,
    "split": {
        "enabled": true,
        "soft_serial_pin": "D1",
        "usb_detect": {
            "enabled": true
        },
        "matrix_pins": {
            "right": {
                "rows": [ "F4", "F5", "F6", "F7"],
                "cols": [ "E6", "D0", "D4", "C6", "D7", "B4" ]
            }
        },
        "transport": {
            "protocol": "serial",
            "watchdog": true,
            "sync": {
                "layer_state": true
            }
        }
    },
    "processor": "atmega32u4",
    "bootloader": "caterina",
    "features": {
        "bootmagic": true,
        "mousekey": false,
        "extrakey": true,
        "console": false,
        "command": false,
        "combo": false,
        "caps_word": true,
        "nkro": true,
        "backlight": false,
        "rgb_matrix": false,
        "rgblight": true,
        "audio": false
    },
    "tapping": {
        "permissive_hold": true,
        "term": 150
    },
    "rgblight" : {
        "led_count": 4,
        "sleep": true,
        "default": {
            "on": true,
            "val": 100,
            "animation": "rainbow_mood"
        },
        "max_brightness": 250,
        "brightness_steps": 100,
        "animations": {
            "breathing": true,
            "knight": true,
            "snake": true,
            "rainbow_mood": true
        },
        "layers" : {
            "blink": false,
            "enabled": true
        },
        "split": true,
        "split_count": [2, 2]
    },
    "ws2812" : {
        "pin": "B5"
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0,0], "label":"Q", "x":0, "y":0},
                {"matrix": [0,1], "label":"W", "x":1, "y":0},
                {"matrix": [0,2], "label":"E", "x":2, "y":0},
                {"matrix": [0,3], "label":"R", "x":3, "y":0},
                {"matrix": [0,4], "label":"T", "x":4, "y":0},
                {"matrix": [0,5], "label":"Y", "x":5, "y":0},

                {"matrix": [4,0], "label":"U", "x":7, "y":0},
                {"matrix": [4,1], "label":"I", "x":8, "y":0},
                {"matrix": [4,2], "label":"O", "x":9, "y":0},
                {"matrix": [4,3], "label":"P", "x":10, "y":0},
                {"matrix": [4,4], "label":"[", "x":11, "y":0},
                {"matrix": [4,5], "label":"]", "x":12, "y":0},

                {"matrix": [1,0], "label":"A", "x":0, "y":1},
                {"matrix": [1,1], "label":"S", "x":1, "y":1},
                {"matrix": [1,2], "label":"D", "x":2, "y":1},
                {"matrix": [1,3], "label":"F", "x":3, "y":1},
                {"matrix": [1,4], "label":"G", "x":4, "y":1},
                {"matrix": [1,5], "label":"H", "x":5, "y":1},

                {"matrix": [5,0], "label":"J", "x":7, "y":1},
                {"matrix": [5,1], "label":"K", "x":8, "y":1},
                {"matrix": [5,2], "label":"L", "x":9, "y":1},
                {"matrix": [5,3], "label":":", "x":10, "y":1},
                {"matrix": [5,4], "label":"'", "x":11, "y":1},
                {"matrix": [5,5], "label":"Enter", "x":12, "y":1},

                {"matrix": [2,0], "label":"Z", "x":0, "y":2},
                {"matrix": [2,1], "label":"X", "x":1, "y":2},
                {"matrix": [2,2], "label":"C", "x":2, "y":2},
                {"matrix": [2,3], "label":"V", "x":3, "y":2},
                {"matrix": [2,4], "label":"B", "x":4, "y":2},
                {"matrix": [2,5], "label":"N", "x":5, "y":2},

                {"matrix": [6,0], "label":"M", "x":7, "y":2},
                {"matrix": [6,1], "label":"<", "x":8, "y":2},
                {"matrix": [6,2], "label":">", "x":9, "y":2},
                {"matrix": [6,3], "label":"?", "x":10, "y":2},
                {"matrix": [6,4], "label":"Shift", "x":11, "y":2},
                {"matrix": [6,5], "label":"Ctrl", "x":12, "y":2},

                {"matrix": [3,0], "label":"Extra1", "x":0, "y":3},
                {"matrix": [3,1], "label":"Extra2", "x":1, "y":3},
